{
  "name": "pi-context-prune",
  "version": "0.10.0",
  "description": "Pi extension package for pruning future context while preserving original tool-call history.",
  "type": "module",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "echo 'nothing to build'",
    "check": "echo 'nothing to check'",
    "validate": "node scripts/validate-context-prune.mjs"
  },
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sylv-io/pi-context-prune.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sylv-io/pi-context-prune/issues"
  },
  "homepage": "https://github.com/sylv-io/pi-context-prune#readme",
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1"
  }
}
